{
	"name": "octogrep",
	"version": "0.0.1",
	"description": "A lightweight GitHub code search CLI for AI agents, outputting in a token-efficient TOON format.",
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"octogrep": "dist/index.js"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsc",
		"format": "biome format --write",
		"lint": "biome lint --write",
		"check": "biome check --write",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"prepare": "lefthook install"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"packageManager": "pnpm@10.30.3",
	"dependencies": {
		"incur": "^0.2.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"@types/node": "^24.11.0",
		"lefthook": "^2.1.2",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
